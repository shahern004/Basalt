<file path="laci-stack-v1.1/utils/skopeo-copy-to-chq.sh">
#!/usr/bin/env bash
# skopeo-copy-to-chq.sh – copy an image to a sub-directory within the same registry

set -euo pipefail

# Determine if we need sudo for Docker commands
if id -nG "$(whoami)" | grep -qw docker; then
  DOCKER_CMD="docker"
else
  DOCKER_CMD="sudo docker"
fi

if [[ "${1}" == "--bootstrap" ]]; then
  # Optional second argument: path to Docker config.json (default to $HOME/.docker/config.json)
  CONFIG_PATH="${2:-$HOME/.docker/config.json}"

  # Ensure script runs as root for bootstrap operations
  if [[ "$(id -u)" -ne 0 ]]; then
    echo "Please note that you may need to run this script as root for bootstrapping with a root-owned config.json" >&2
  fi

  # Ensure Docker volume for skopeo auth exists
  VOLUME_NAME="dot-docker-dir"
  if ! ${DOCKER_CMD} volume inspect "$VOLUME_NAME" >/dev/null 2>&1; then
    ${DOCKER_CMD} volume create "$VOLUME_NAME" >/dev/null 2>&1 || true
  fi

  # Copy host Docker config into the volume if it exists
  if [[ -f "$CONFIG_PATH" ]]; then
    ${DOCKER_CMD} run --rm -v "$VOLUME_NAME:/root/.docker" -v "$CONFIG_PATH:/config.json:ro" alpine sh -c 'mkdir -p /root/.docker && cp /config.json /root/.docker/config.json' >/dev/null 2>&1 || true
  else
    echo "Warning: $CONFIG_PATH not found, skipping copy" >&2
    exit 1
  fi
  exit 0
elif [[ $# -ne 2 ]] || [[ $# -le 0 ]]; then
  echo "copy an image to the laci-chq repo"
  echo "Usage: $0 <source-repo-slug:tag> <dest-subdir-repo-slug:tag>"
  echo "Example: $0 laci-docker-io/ubuntu:latest laci/ubuntu:latest"
  echo "Example: $0 --bootstrap # to set up docker repo auth"
  exit 1
fi

#SKOPEO_IMAGE="quay.io/skopeo/stable:latest"
SKOPEO_IMAGE="lnsvr0310.gcsd.harris.com:8443/laci-docker/skopeo:latest"

SRC_SLUG="$1"          # e.g. laci-docker-io/ubuntu:latest
DEST_SUBDIR_SLUG="$2"  # e.g. laci/ubuntu:latest

REGISTRY="docker://lnsvr0310.gcsd.harris.com:8443"

SRC="${REGISTRY}/${SRC_SLUG}"
DEST="${REGISTRY}/lacichq-docker/${DEST_SUBDIR_SLUG}"

# Define colors for output
GREY='\e[90m'
GREEN='\e[32m'
BLUE='\e[34m'
RESET='\e[0m'

echo -e "${GREY}${REGISTRY}${RESET}/${BLUE}${SRC_SLUG}${RESET} -> ${GREY}${REGISTRY}${RESET}/lacichq-docker/${GREEN}${DEST_SUBDIR_SLUG}${RESET}"

# Run skopeo copy via the container wrapper
${DOCKER_CMD} run -v dot-docker-dir:/root/.docker/:ro \
    ${SKOPEO_IMAGE} copy \
    --authfile=/root/.docker/config.json \
    --src-tls-verify=false \
    --dest-tls-verify=false \
    "${SRC}" "${DEST}"
</file>

