    "laci-docker-io/onyxdotapp/onyx-model-server:v2.0.3              onyxdotapp/onyx-model-server:v2.0.3"
    "laci-docker-io/onyxdotapp/onyx-web-server:v2.0.3                onyxdotapp/onyx-web-server:v2.0.3"
    "laci-docker-io/vespaengine/vespa:8.526.15                       vespaengine/vespa:8.526.15"
)

# should work, but times out due to big layers
vllm=(
    "laci-docker-io/vllm/vllm-openai:v0.17.1                         laci/vllm/vllm-openai:v0.17.1"
