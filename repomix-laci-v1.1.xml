)

authentik=(
    "laci-ghcr-io/goauthentik/server:2026.2.1                        goauthentik/server:2026.2.1"
)

openwebui=(
    "laci-docker/laci/open-webui:v0.8.10                             laci/open-webui:v0.8.10"
)

onyx=(
