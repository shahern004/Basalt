# sudo docker image tag harbor.laci.l3harris.com/artifactory/laci-docker-io/vllm/vllm-openai:v0.17.1 lnsvr0310.gcsd.harris.com:8443/lacichq-docker/vllm/vllm-openai:v0.17.1
