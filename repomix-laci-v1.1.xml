<file path="laci-stack-v1.1/inference/litellm/docker-compose.yaml">
include:
  - ./db/include.yaml
services:
  litellm:
    image: ${LITELLM_IMAGE:?error}:${LITELLM_TAG:?error}
    restart: always
    ports:
      - ${LITELLM_PORT:?error}:8000
    volumes:
      - ./litellm-config.yaml:/app/config.yaml
    command: --port ${LITELLM_PORT:?error} --config config.yaml
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      OPENAI_API_KEY: ${OPENAI_API_KEY:?error}
      COHERE_API_KEY: ${COHERE_API_KEY:?error}
      LITELLM_MASTER_KEY: ${LITELLM_MASTER_KEY:?error} 
