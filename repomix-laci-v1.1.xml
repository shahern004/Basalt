      VLLM_ENGINE_ITERATION_TIMEOUT_S: 1200 # 20 mins
      VLLM_EXECUTE_MODEL_TIMEOUT_SECONDS: 1200 # 20 mins
      VLLM_RPC_TIMEOUT: 1200000 # (ms) 20 mins
    shm_size: 10gb
    ipc: host

    volumes:
      - ${HF_CACHE:?/mnt/hf}:/root/.cache/huggingface

    command: >
      --host 0.0.0.0
      --gpu-memory-utilization 0.9
      --tensor-parallel-size 4
      --max-model-len 64000
      --model openai/gpt-oss-120b
    env_file:
      - ../.env
    ports:
      - ${VLLM_API_PORT:-8001}:8000

    logging:
      driver: json-file
      options:
        max-file: "3"
        max-size: '10m'

    healthcheck:
      test: ["CMD", "curl", "-f", "http://0.0.0.0:8000/health/"]
      interval: 30s
      timeout: 3s
      start_period: 45s
      start_interval: 5s

    deploy:
      replicas: 1
      restart_policy:
        max_attempts: 5
        condition: on-failure
        delay: 10s
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: 4
              capabilities: [gpu]

    networks:
      - inference-endpoint
networks:
  inference-endpoint:
    external: true
</file>

