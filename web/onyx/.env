# Generated from env.template for Basalt local development
# See env.template for all available configuration options

DOCKER_REPO_OVERRIDE=
IMAGE_TAG=latest

################################################################################
## Auth — Authentik OIDC SSO
################################################################################
AUTH_TYPE=oidc
OAUTH_CLIENT_ID=<from-authentik-provider>
OAUTH_CLIENT_SECRET=<from-authentik-provider>
# Docker DNS: authentik-server on the shared proxy network, internal port 9000
OPENID_CONFIG_URL=http://authentik-server:9000/application/o/onyx/.well-known/openid-configuration
WEB_DOMAIN=https://onyx.basalt.local

################################################################################
## Database
################################################################################
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

################################################################################
## MinIO/S3
################################################################################
S3_ENDPOINT_URL=http://minio:9000
S3_AWS_ACCESS_KEY_ID=minioadmin
S3_AWS_SECRET_ACCESS_KEY=minioadmin
S3_FILE_STORE_BUCKET_NAME=onyx-file-store-bucket
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

################################################################################
## Logging
################################################################################
LOG_LEVEL=info
LOG_ALL_MODEL_INTERACTIONS=False
LOG_ONYX_MODEL_INTERACTIONS=False
LOG_INDIVIDUAL_MODEL_TOKENS=False

################################################################################
## Feature Flags
################################################################################
ENABLE_PAID_ENTERPRISE_EDITION_FEATURES=false
USE_IAM_AUTH=false

################################################################################
## Service Pointers
################################################################################
POSTGRES_HOST=relational_db
VESPA_HOST=index
REDIS_HOST=cache
MODEL_SERVER_HOST=inference_model_server
INDEXING_MODEL_SERVER_HOST=indexing_model_server
INTERNAL_URL=http://api_server:8080
