#####################################################################
## vLLM Image Settings
#####################################################################
VLLM_IMAGE=vllm/vllm-openai
VLLM_TAG=v0.10.2

#####################################################################
## Model Configuration
#####################################################################
# Model weights live on ext4 inside basalt-host WSL2 distro.
# No more 9p bridge mount from Windows — vLLM cold start < 60s.
MODEL_PATH=/opt/basalt/models
