#####################################################################
## Image tag / repo settings
#####################################################################

LITELLM_IMAGE=ghcr.io/berriai/litellm-database
LITELLM_TAG=main-v1.41.14

REDIS_IMAGE=redis
REDIS_TAG=alpine

POSTGRES_IMAGE=postgres
POSTGRES_TAG=15.2-alpine

#####################################################################
## Database connection settings
#####################################################################

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=litellm
DATABASE_URL="postgres://$POSTGRES_USER:$POSTGRES_PASSWORD@postgres:5432/$POSTGRES_DB"

REDIS_AUTH=e50bf48b9c2bbc022bcd024c995101ecfd34a8e6a97e46b01fb63bbc804b3573

#####################################################################
## LiteLLM settings
#####################################################################

LITELLM_PORT=8000
LITELLM_MASTER_KEY=sk-120fb1a38a2a6ca5ef2745fe507e50fe479a509e6667e62dd4445d97b3ae8cf0

# Not needed for vLLM-only deployment, but kept for compatibility
OPENAI_API_KEY=not-needed
COHERE_API_KEY=not-needed

#####################################################################
## LiteLLM -> Langfuse connection settings
#####################################################################

# Docker DNS: langfuse-web service on the shared proxy network, internal port 3000
LANGFUSE_HOST=http://langfuse-web:3000
LANGFUSE_AUTH=cGstZXhhbXBsZWtleTpzay1leGFtcGxla2V5
LANGFUSE_PUBLIC_KEY=pk-examplekey
LANGFUSE_SECRET_KEY=sk-examplekey
