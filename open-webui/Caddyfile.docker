# Run with
#    caddy run --envfile ./example.env --config ./Caddyfile.docker
#
# This is configured for
#    - Automatic HTTPS (even for localhost)
#    - Reverse Proxying to Ollama API Base URL (http://localhost:11434/api)
#    - CORS
#    - HTTP Basic Auth API Tokens (uncomment basicauth section)

# https://github.com/open-webui/open-webui/pull/20/files
# https://github.com/open-webui/open-webui/pull/1347#issuecomment-2027740589

{
	debug
}

##################
# Macro Snippets #
##################

# Macro for optional HTTP Basic Auth
(maybe-basic-auth) {
	@match-enforce-auth `"{$OLLAMA_API_TOKEN_DIGEST}".size() > 0`
	basicauth @match-enforce-auth {
		{$OLLAMA_API_ID} {$OLLAMA_API_TOKEN_DIGEST}
	}
}

# Macro for CORS "Simple Requests"
(cors-simple) {
	@match-cors-request-simple {
		not header Origin "{http.request.scheme}://{http.request.host}"
		header Origin "{http.request.header.origin}"
		method GET HEAD POST
	}
	handle @match-cors-request-simple {
		header {
			Access-Control-Allow-Origin "*"
			Access-Control-Expose-Headers "*"
			defer
		}
	}
}

# Macro for CORS Preflight Requests + Requests
(cors-api) {
	@match-cors-api-preflight {
		not header Origin "{http.request.scheme}://{http.request.host}"
		header Origin "{http.request.header.origin}"
		method OPTIONS
	}
	handle @match-cors-api-preflight {
		header {
			Access-Control-Allow-Origin "{http.request.header.origin}"
			Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
			Access-Control-Allow-Headers "Origin, Accept, Authorization, Content-Type, X-Requested-With, X-Authentik-Email, X-Authentik-Name"
			Access-Control-Allow-Credentials "true"
			Access-Control-Max-Age "3600"
			defer
		}
		respond "" 204
	}

	@match-cors-api-request {
		not header Origin "{http.request.scheme}://{http.request.host}"
		header Origin "{http.request.header.origin}"
		not method OPTIONS
	}
	handle @match-cors-api-request {
		header {
			Access-Control-Allow-Origin "{http.request.header.origin}"
			Access-Control-Allow-Credentials "true"
			Access-Control-Max-Age "3600"
			defer
		}
	}
}

#################
# Server Config #
#################

# disables automatic HTTPS certs, and handles any hostname
:8888 {

	## Set OLLAMA_API_TOKEN_DIGEST to enable HTTP Basic Auth
	# (see .example.env for how to generate tokens)
	#import maybe-basic-auth

	handle /api/* {
		# Comment to disable CORS
		import cors-api
	}

	handle /* {
        # Uncomment to enable CORS
		import cors-simple
	}

	reverse_proxy http://open-webui:8080 {
		# only replaces the value if they are set in the .env
		header_up X-Authentik-Email "(.*)" "{$AUTHENTIK_EMAIL:$1}"
		header_up X-Authentik-Name "(.*)" "{$AUTHENTIK_NAME:$1}"
	}
}
